<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<fx:root alignment="TOP_RIGHT"
         maxWidth="1.7976931348623157E308"
         type="javafx.scene.layout.HBox"
         spacing="8"
         xmlns="http://javafx.com/javafx/21"
         xmlns:fx="http://javafx.com/fxml/1">
    <children>
        <VBox fx:id="bubbleBox" maxWidth="1.7976931348623157E308"
              HBox.hgrow="ALWAYS">
            <children>
                <Label fx:id="nameLabel" text="Name"
                       styleClass="name-label" />
                <Label fx:id="dialog" text="Label"
                       wrapText="true"
                       minHeight="-Infinity"
                       styleClass="chat-bubble" />
            </children>
        </VBox>
        <ImageView fx:id="displayPicture"
                   fitHeight="36.0" fitWidth="36.0"
                   pickOnBounds="true"
                   preserveRatio="true" />
    </children>
    <padding>
        <Insets bottom="4.0" left="10.0" right="10.0" top="4.0" />
    </padding>
</fx:root>
